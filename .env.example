# m3u-push-relay Configuration

# Server
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=info

# Rate limits (abuse guard — no shared secret is used, see README).
RATE_LIMIT_PER_IP_PER_MINUTE=60
RATE_LIMIT_PER_TOKEN_PER_HOUR=20

# FCM (Firebase) — handles both Android and iOS mobile push.
# Download from Firebase Console > Project Settings > Service Accounts >
# Generate new private key. On Render this is a Secret File, mounted at
# /etc/secrets/<filename>.
#
# iOS delivery works because the APNs auth key (.p8) is uploaded directly in
# the Firebase Console (Project Settings > Cloud Messaging > Apple app
# configuration) — this relay never touches Apple credentials directly.
FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
