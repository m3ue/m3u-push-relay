# m3u-push-relay Configuration

# Server
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=info

# Shared secret that each self-hosted m3u-editor instance must send in the
# X-Relay-Secret header. Generate with: openssl rand -hex 32
RELAY_SHARED_SECRET=

# APNs (iOS/tvOS) — auth-key based (.p8), not a per-app push certificate.
# Path to the .p8 file. On Render this is a Secret File, mounted at /etc/secrets/<filename>.
APNS_KEY_PATH=./secrets/AuthKey.p8
# Key ID of the .p8 key (Apple Developer > Certificates, IDs & Profiles > Keys)
APNS_KEY_ID=
# Your Apple Developer Team ID
APNS_TEAM_ID=
# Bundle ID of the app the push is for (used as the apns-topic)
APNS_TOPIC=
# Use the APNs sandbox (development builds). Set to false for TestFlight/App Store builds.
APNS_USE_SANDBOX=false

# FCM (Android) — HTTP v1 API, service account JSON.
# On Render this is a Secret File, mounted at /etc/secrets/<filename>.
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
